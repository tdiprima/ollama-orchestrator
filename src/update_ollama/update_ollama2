#!/usr/bin/env bash
# ============================================================
# update_ollama2 - Update Ollama, configure models path, restart service
# Author: tdiprima
#
# PURPOSE:  Ensures OLLAMA_MODELS=/home/ollama is set in the
#           systemd service file, then restarts the service.
# SECURITY: This script runs as root (via sudoers).
#           No passwords are hard-coded anywhere.
#           No "sudo" calls needed inside this script.
# SETUP:    Run setup_ollama_sudo.sh once to allow
#           passwordless execution of THIS script only.
# ============================================================
# journalctl -t "update_ollama2"

set -eE

trap 'logger -t update_ollama2 "=== Ollama update FAILED at line $LINENO (exit $?) ==="' ERR

export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"

OLLAMA_MODELS_VALUE='OLLAMA_MODELS=/home/ollama'
OLLAMA_HOST_VALUE='OLLAMA_HOST=0.0.0.0:11434'
SERVICE_FILE="/etc/systemd/system/ollama.service"
LOG_TAG="update_ollama2"

# ------ One function per task ------

log_msg() {
    # Prints to both terminal and syslog (handy for cron debugging)
    echo "$1"
    logger -t "${LOG_TAG}" "$1"
}

install_latest_ollama() {
    log_msg "Downloading and installing latest Ollama..."
    timeout --kill-after=30 600 bash -c 'curl -fsSL https://ollama.com/install.sh | sh'
    log_msg "Installed: $(ollama --version 2>/dev/null | head -1)"
}

ensure_env_config() {
    # Make sure the OLLAMA_MODELS environment line is in the service file
    if ! grep -q "Environment=\"${OLLAMA_MODELS_VALUE}\"" "${SERVICE_FILE}"; then
        log_msg "Adding OLLAMA_MODELS to service file..."
        sed -i "/Environment=/a Environment=\"${OLLAMA_MODELS_VALUE}\"" "${SERVICE_FILE}"
    else
        log_msg "OLLAMA_MODELS already configured."
    fi

    # Make sure the OLLAMA_HOST environment line is in the service file
    if ! grep -q "Environment=\"${OLLAMA_HOST_VALUE}\"" "${SERVICE_FILE}"; then
        log_msg "Adding OLLAMA_HOST to service file..."
        sed -i "/Environment=/a Environment=\"${OLLAMA_HOST_VALUE}\"" "${SERVICE_FILE}"
    else
        log_msg "OLLAMA_HOST already configured."
    fi
}

restart_service() {
    log_msg "Reloading systemd and restarting Ollama..."
    systemctl daemon-reload
    sleep 3
    systemctl restart ollama.service
    sleep 3
    log_msg "Service restarted."
}

verify_connection() {
    log_msg "Testing Ollama API..."
    if curl -sf http://localhost:11434/api/version; then
        log_msg "Ollama is responding."
    else
        log_msg "WARNING: Ollama did not respond on port 11434."
    fi
}

# ------ Main ------

main() {
    log_msg "=== Ollama update started ==="
    install_latest_ollama
    ensure_env_config
    restart_service
    verify_connection
    log_msg "=== Ollama update finished ==="
}

main "$@"
